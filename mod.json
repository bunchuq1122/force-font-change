{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "bunchuq1122.force-font-change",
	"name": "Force Font CHange",
	"version": "v1.0.0",
	"developer": "Bunchuq1122",
	"description": "Force change the font.",
	"dependencies": {
		"geode.node-ids": ">=v1.20.0",
		"alphalaneous.alphas_geode_utils": ">=1.2.1"
	},
	"settings": {
		"customfnt": {
			"type": "bool",
			"name": "Use Custom Font file",
			"default": false,
			"description": "Use custom .fnt file in your pc, this option is very <cr>dangerous</c>, Recommended files: *gjFont<cj>XX</c>-hd.fnt*. <cj>XX</c> is font number"
		},
		"font-file": {
			"type": "file",
			"name": "Custom Font File (.fnt)",
			"description": "Select a .fnt file",
			"default": "Please select a font file",
			"enable-if": "customfnt",
			"control": {
				"dialog": "open",
				"filters": [{
					"files": ["*.fnt"],
					"description": "BMFont Files"
				}]
			}
		}
	},
	"links": {
		"community": "https://github.com/bunchuq1122/force-font-change",
		"source": "https://github.com/bunchuq1122/force-font-change"
	}
}
